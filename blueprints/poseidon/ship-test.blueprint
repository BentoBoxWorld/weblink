        "inventory": {
          "0": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:experience_bottle\n  count: 1\n  schema_version: 1\n",
          "1": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:emerald\n  count: 3\n  schema_version: 1\n",
          "2": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:iron_nugget\n  count: 1\n  schema_version: 1\n",
          "3": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:lapis_lazuli\n  count: 1\n  schema_version: 1\n",
          "4": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:trident\n  count: 1\n  schema_version: 1\n",
          "5": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:iron_nugget\n  count: 2\n  schema_version: 1\n",
          "6": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:emerald\n  count: 1\n  schema_version: 1\n",
          "7": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:lapis_lazuli\n  count: 1\n  schema_version: 1\n",
          "8": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:iron_nugget\n  count: 1\n  schema_version: 1\n",
          "9": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:iron_nugget\n  count: 1\n  schema_version: 1\n",
          "10": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:emerald\n  count: 1\n  schema_version: 1\n",
          "11": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:iron_ingot\n  count: 1\n  schema_version: 1\n",
          "12": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:emerald\n  count: 2\n  schema_version: 1\n",
          "13": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:written_book\n  count: 1\n  components:\n    minecraft:written_book_content: '{author:\"Unknown\",generation:3,pages:[{raw:\"I\n      remember sinking.\\n\\nNot drowning, just... sinking.\\n\\nThe cold wrapped around\n      me, but I felt no panic, no need for air. My body refused to float, as if the\n      ocean itself had claimed me.\"},{raw:\"Then-consciousness. I awoke to the quiet\n      hum of the deep, my limbs light, the water a second skin.\\n\\nBubbles drifted\n      past, but they weren''t mine. I exhaled, expecting panic, expecting pain-but\n      no, I breathed as if I had always belonged here.\"},{raw:\"I should be dead.\\n\\nBut\n      I am not.\\n\\nA shipwreck looms nearby, broken and half-swallowed by coral. The\n      remnants of a past I cannot recall. My hands grasp at the splintered wood.\"},{raw:\"Among\n      the wreckage, a chest. Supplies, perhaps left for me, as if someone knew I would\n      awaken here?\\n\\nWas I meant to survive?\\n\\nOr was I meant to stay lost?\"}],resolved:1b,title:{raw:\"Book\n      1: The First Breath\"}}'\n  schema_version: 1\n",
          "14": "is:\n  ==: org.bukkit.inventory.ItemStack\n  DataVersion: 4790\n  id: minecraft:iron_ingot\n  count: 1\n  schema_version: 1\n",
